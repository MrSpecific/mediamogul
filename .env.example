# Copy to `.env`. Read by the Prisma CLI (migrate/push/studio) and Vite
# (only VITE_-prefixed vars reach the browser).

# Neon pooled connection string — Neon dashboard → Connection Details.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/dbname?sslmode=require"

# Neon Auth client URL (Neon Console → Auth → Configuration). VITE_-prefixed so
# the browser can read it; set the SAME url as NEON_AUTH_URL in wrangler.jsonc.
VITE_NEON_AUTH_URL=""

# Google Analytics 4 Measurement ID (Admin → Data Streams → your web stream).
# Only loads in production builds. Must be set at BUILD time (it's inlined by
# Vite), so provide it in the deploy/CI environment too.
VITE_GA_MEASUREMENT_ID=""

# NOTE: Worker-side secrets (Stripe keys, TMDB) do NOT go here — they live in
# `.dev.vars` (see .dev.vars.example) for dev, and Wrangler secrets in prod.
