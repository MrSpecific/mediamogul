// mediamogul — media consumption tracking platform.
// Prisma 7 schema, Rust-free `prisma-client` generator targeting Cloudflare Workers.
// Docs: https://www.prisma.io/docs/orm/prisma-client/deployment/edge/deploy-to-cloudflare
//
// Convention: Prisma-style names in this file (PascalCase models, camelCase
// fields) mapped to snake_case tables/columns in Postgres via @@map / @map.

generator client {
  provider     = "prisma-client"
  output       = "../worker/generated/prisma"
  runtime      = "workerd"
  moduleFormat = "esm"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum MediaType {
  MOVIE
  TV_SHOW
  BOOK
  AUDIOBOOK
  MAGAZINE
}

/// Content/maturity rating system (e.g. MPAA film ratings, US TV Parental
/// Guidelines). The available codes per system live in the ContentRating table.
enum RatingSystem {
  MPAA // US film ratings: G, PG, PG-13, R, NC-17
  US_TV // US TV Parental Guidelines: TV-Y … TV-MA
}

/// How two media items relate.
enum MediaRelationType {
  ALTERNATE_FORMAT // same work, different format (book ↔ audiobook ↔ ebook)
  ADAPTATION // adapted across media (book → movie, etc.)
  TRANSLATION // a translated edition
}

/// How a catalog item got here.
enum MediaSource {
  OFFICIAL // curated / trusted
  USER_SUBMITTED // added by a user by hand
  SCRAPED // imported from a public source
}

/// External catalog cross-references.
enum ExternalSource {
  IMDB
  TMDB
  GOODREADS
  ISBN
  OPEN_LIBRARY
  WIKIDATA
  LIBBY
  CUSTOM
}

/// State of a single consumption record (a user can have many per media).
enum EntryStatus {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  ABANDONED
}

enum MediaAssetKind {
  COVER // front cover / poster
  BACKDROP // wide hero/backdrop art
  OTHER
}

enum Visibility {
  PRIVATE
  UNLISTED
  PUBLIC
}

/// Billing tier. Feature gating + pricing live in shared/tiers.ts.
enum SubscriptionTier {
  FREE
  STANDARD
}

/// Major streaming platforms we can link a movie/TV show out to. "Available to
/// stream" only (no rent/buy). Extend as needed.
enum StreamingProvider {
  NETFLIX
  MAX // HBO Max / Max
  APPLE_TV
  HULU
  PARAMOUNT_PLUS
  DISNEY_PLUS
  PRIME_VIDEO
  PEACOCK
  TUBI
  STARZ
  YOUTUBE
  VIMEO
}

/// The kind of contribution a person made to a media item.
enum CreditRole {
  AUTHOR // books
  ILLUSTRATOR
  EDITOR // magazines, books
  DIRECTOR // movies
  CREATOR // tv (showrunner/creator)
  NARRATOR // audiobooks
  WRITER
  PRODUCER
  CAST // actors
  OTHER
}

enum ContentSubmissionKind {
  MEDIA_EDIT
  NEW_MEDIA
  DUPLICATE
  INCORRECT_INFO
  ABUSE
  OTHER
}

enum ContentSubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

/// App role. Normally derived from the Neon Auth JWT; this optional column is an
/// admin-set override stored in our DB (null = defer to the JWT/email allowlist).
/// Mirrors the AppRole union in worker/auth.ts. See effectiveRole().
enum AppRole {
  USER
  CONTRIBUTOR
  EDITOR
  ADMIN
}

// ---------------------------------------------------------------------------
// Users (profile). `id` is the Neon Auth user id (JWT `sub`); rows are
// upserted on first authenticated request. Neon Auth also maintains its own
// `neon_auth.users_sync` table — this is our app-owned profile alongside it.
// ---------------------------------------------------------------------------

model User {
  id                   String           @id // Neon Auth user id
  username             String           @unique
  displayName          String?          @map("display_name")
  bio                  String?
  avatarUrl            String?          @map("avatar_url")
  tier                 SubscriptionTier @default(FREE)
  // Admin-set role override (null = defer to JWT/email allowlist). See auth.ts.
  appRole              AppRole?         @map("app_role")
  // Whether the profile is visible to logged-out visitors. Users can toggle it;
  // defaults to public. Non-public profiles are still visible to the owner and admins.
  profilePublic        Boolean          @default(true) @map("profile_public")
  // Set when an admin deactivates the account; blocks API access while non-null.
  deactivatedAt        DateTime?        @map("deactivated_at")
  stripeCustomerId     String?          @unique @map("stripe_customer_id")
  stripeSubscriptionId String?          @map("stripe_subscription_id")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")

  addedMedia                 MediaItem[]         @relation("MediaCreatedBy")
  uploadedAssets             MediaAsset[]
  entries                    MediaEntry[]
  ratings                    Rating[]
  reviews                    Review[]
  lists                      MediaList[]
  savedLists                 SavedList[]
  starredLists               StarredList[]
  collaborations             ListCollaborator[]  @relation("collaborator")
  sentListInvites            ListCollaborator[]  @relation("inviter")
  notifications              Notification[]      @relation("recipient")
  actedNotifications         Notification[]      @relation("actor")
  following                  Follow[]            @relation("follower") // rows where this user follows someone
  followers                  Follow[]            @relation("following") // rows where this user is followed
  contentSubmissions         ContentSubmission[] @relation("submissionAuthor")
  reviewedContentSubmissions ContentSubmission[] @relation("submissionReviewer")
  adminActions               AdminAuditLog[]     @relation("auditActor")
  auditEntries               AdminAuditLog[]     @relation("auditTarget")
  recommendationFeedback     RecommendationFeedback[]

  @@index([username])
  @@index([deactivatedAt])
  @@map("users")
}

/// Append-only audit trail for admin actions on users (role/tier/deactivation).
model AdminAuditLog {
  id           String   @id @default(uuid())
  actorId      String   @map("actor_id")
  targetUserId String   @map("target_user_id")
  action       String // e.g. "role.change", "tier.change", "deactivate", "reactivate"
  detail       Json? // { from, to } or similar context
  createdAt    DateTime @default(now()) @map("created_at")

  actor  User @relation("auditActor", fields: [actorId], references: [id])
  target User @relation("auditTarget", fields: [targetUserId], references: [id])

  @@index([targetUserId, createdAt])
  @@index([actorId, createdAt])
  @@map("admin_audit_log")
}

// ---------------------------------------------------------------------------
// Media catalog
// ---------------------------------------------------------------------------

model MediaItem {
  id               String    @id @default(uuid())
  type             MediaType
  title            String
  subtitle         String? // e.g. a book's subtitle or a film's tagline
  sortTitle        String?   @map("sort_title")
  coverImageUrl    String?   @map("cover_image_url")
  shortDescription String?   @map("short_description") // one/two-liner for cards
  synopsis         String? // full description
  releaseDate      DateTime? @map("release_date")
  originalLanguage String?   @map("original_language")
  wikipediaUrl     String?   @map("wikipedia_url")

  // Type-specific attributes as first-class columns. Only the ones relevant to
  // a given media type are populated. People (authors/directors/…) are modeled
  // relationally via Credit to support multiples.
  publisher      String? // books, magazines
  pageCount      Int?    @map("page_count") // books
  runtimeMinutes Int?    @map("runtime_minutes") // movies; tv per-episode
  seasons        Int? // tv
  episodes       Int? // tv

  // Refresh hints for scheduled discovery (services/discovery.ts). `showStatus`
  // is the source's production status (e.g. "Running"/"Ended" from TVmaze);
  // `nextReleaseDate` is the next known air/release date; `lastRefreshedAt` is
  // when we last pulled fresh data; `refreshEnabled` lets the cron skip items
  // (e.g. finished shows) without deleting them.
  showStatus      String?   @map("show_status")
  nextReleaseDate DateTime? @map("next_release_date")
  lastRefreshedAt DateTime? @map("last_refreshed_at")
  refreshEnabled  Boolean   @default(true) @map("refresh_enabled")

  source          MediaSource    @default(USER_SUBMITTED)
  visibility      Visibility     @default(PUBLIC)
  archivedAt      DateTime?      @map("archived_at")
  createdById     String?        @map("created_by_id")
  createdBy       User?          @relation("MediaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  // Age/maturity rating (MPAA for film, US TV Parental Guidelines for TV, …).
  contentRatingId String?        @map("content_rating_id")
  contentRating   ContentRating? @relation(fields: [contentRatingId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  externalIds       ExternalId[]
  streaming         StreamingAvailability[]
  credits           Credit[]
  genres            MediaGenre[]
  assets            MediaAsset[]
  tvSeasons         Season[] // Season rows (distinct from the `seasons` count column)
  entries           MediaEntry[]
  ratings           Rating[]
  reviews           Review[]
  listItems         MediaListItem[]
  seriesEntries     SeriesEntry[]
  relationsFrom     MediaRelation[]     @relation("relationsFrom")
  relationsTo       MediaRelation[]     @relation("relationsTo")
  feedback          ContentSubmission[] @relation("submissionTarget")
  duplicateFeedback ContentSubmission[] @relation("submissionDuplicate")
  recommendationFeedback RecommendationFeedback[]

  @@index([type])
  @@index([title])
  @@index([createdById])
  @@index([contentRatingId])
  // Scheduled-refresh queue: eligible items by type, ordered by staleness.
  @@index([type, refreshEnabled, lastRefreshedAt])
  @@map("media_items")
}

/// Where a movie/TV show can be streamed, with a deep link out. "Available to
/// stream" only (no rent/buy). Region-scoped (default US) for future expansion.
/// Manually curated today; structured for automated population/refresh later.
model StreamingAvailability {
  id          String            @id @default(uuid())
  mediaItemId String            @map("media_item_id")
  mediaItem   MediaItem         @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  provider    StreamingProvider
  region      String            @default("US")
  url         String
  addedById   String?           @map("added_by_id")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@unique([mediaItemId, provider, region])
  @@index([mediaItemId])
  @@map("streaming_availability")
}

/// Singleton runtime config for scheduled discovery/refresh (see the admin
/// Control Center + services/discovery.ts). One row, id = "singleton". Note the
/// cron *schedule* itself lives in wrangler.jsonc (deploy-time); these control
/// what each run does.
model CronConfig {
  id                     String   @id @default("singleton")
  seasonRefreshEnabled   Boolean  @default(true) @map("season_refresh_enabled")
  newReleaseDiscovery    Boolean  @default(false) @map("new_release_discovery")
  // Which sources scheduled tasks may pull from.
  useTvmaze              Boolean  @default(true) @map("use_tvmaze")
  useWikidata            Boolean  @default(true) @map("use_wikidata")
  useOpenLibrary         Boolean  @default(true) @map("use_open_library")
  useTmdb                Boolean  @default(false) @map("use_tmdb")
  // How much work per run, and the minimum age before an item is re-refreshed.
  refreshBatchSize       Int      @default(8) @map("refresh_batch_size")
  minRefreshHours        Int      @default(24) @map("min_refresh_hours")
  lastRunAt              DateTime? @map("last_run_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("cron_config")
}

/// Flexible user contributions and reports. Proposed changes live in JSON so
/// the workflow can grow without a schema change for every editable field.
model ContentSubmission {
  id                   String                  @id @default(uuid())
  kind                 ContentSubmissionKind
  status               ContentSubmissionStatus @default(PENDING)
  submitterId          String                  @map("submitter_id")
  submitter            User                    @relation("submissionAuthor", fields: [submitterId], references: [id], onDelete: Cascade)
  targetMediaItemId    String?                 @map("target_media_item_id")
  targetMediaItem      MediaItem?              @relation("submissionTarget", fields: [targetMediaItemId], references: [id], onDelete: Cascade)
  duplicateMediaItemId String?                 @map("duplicate_media_item_id")
  duplicateMediaItem   MediaItem?              @relation("submissionDuplicate", fields: [duplicateMediaItemId], references: [id], onDelete: SetNull)
  proposedData         Json?                   @map("proposed_data")
  message              String?
  reviewerId           String?                 @map("reviewer_id")
  reviewer             User?                   @relation("submissionReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  adminNote            String?                 @map("admin_note")
  reviewedAt           DateTime?               @map("reviewed_at")
  createdAt            DateTime                @default(now()) @map("created_at")
  updatedAt            DateTime                @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([submitterId])
  @@index([targetMediaItemId])
  @@map("content_submissions")
}

model ExternalId {
  id          String         @id @default(uuid())
  mediaItemId String         @map("media_item_id")
  mediaItem   MediaItem      @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  source      ExternalSource
  value       String
  url         String?

  @@unique([source, value]) // one catalog item per external id
  @@unique([mediaItemId, source]) // one id per source per item
  @@index([mediaItemId])
  @@map("external_ids")
}

/// A person's contribution to a media item (many per item, ordered). Names are
/// denormalized; `externalId` (e.g. Wikidata QID, TMDB person id) is kept for
/// future person-linking / "all works by X".
model Credit {
  id          String     @id @default(uuid())
  mediaItemId String     @map("media_item_id")
  mediaItem   MediaItem  @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  role        CreditRole
  name        String
  externalId  String?    @map("external_id")
  position    Int        @default(0)
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([mediaItemId])
  @@index([role, name])
  @@map("credits")
}

/// A genre/category. `applicableTypes` limits which media types it applies to
/// (empty = all). New genres can be created when scraping or by admins.
model Genre {
  id              String       @id @default(uuid())
  name            String       @unique
  slug            String       @unique
  applicableTypes MediaType[]  @map("applicable_types")
  createdAt       DateTime     @default(now()) @map("created_at")
  media           MediaGenre[]

  @@map("genres")
}

/// A content/maturity rating available for assignment (e.g. MPAA "PG-13", US TV
/// "TV-MA"). A fixed catalog seeded per system; media point at one via FK.
model ContentRating {
  id              String       @id @default(uuid())
  system          RatingSystem
  /// Short label shown in the badge, e.g. "PG-13" or "TV-MA".
  code            String
  /// Full name, e.g. "Parents Strongly Cautioned".
  name            String
  description     String?
  applicableTypes MediaType[]  @map("applicable_types")
  /// Severity order within a system, lowest (most permissive) first.
  rank            Int          @default(0)
  createdAt       DateTime     @default(now()) @map("created_at")
  media           MediaItem[]

  @@unique([system, code])
  @@map("content_ratings")
}

/// Media ↔ genre join (a media item can have several genres).
model MediaGenre {
  mediaItemId String    @map("media_item_id")
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  genreId     String    @map("genre_id")
  genre       Genre     @relation(fields: [genreId], references: [id], onDelete: Cascade)

  @@id([mediaItemId, genreId])
  @@index([genreId])
  @@map("media_genres")
}

/// A directed link between two media items (book → its movie adaptation, a
/// book ↔ its audiobook, an original ↔ a translation, …).
model MediaRelation {
  id        String            @id @default(uuid())
  fromId    String            @map("from_id")
  from      MediaItem         @relation("relationsFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId      String            @map("to_id")
  to        MediaItem         @relation("relationsTo", fields: [toId], references: [id], onDelete: Cascade)
  type      MediaRelationType
  note      String?
  createdAt DateTime          @default(now()) @map("created_at")

  @@unique([fromId, toId, type])
  @@index([fromId])
  @@index([toId])
  @@map("media_relations")
}

/// A named series/collection (a trilogy, a book saga, …).
model Series {
  id          String        @id @default(uuid())
  title       String
  description String?
  createdById String?       @map("created_by_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  entries     SeriesEntry[]

  @@map("series")
}

/// Membership of a media item in a series at a given position ("Book 1 of 3").
model SeriesEntry {
  id          String    @id @default(uuid())
  seriesId    String    @map("series_id")
  series      Series    @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  mediaItemId String    @map("media_item_id")
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  position    Int // 1-based order within the series

  @@unique([seriesId, mediaItemId])
  @@unique([seriesId, position])
  @@index([mediaItemId])
  @@map("series_entries")
}

/// An uploaded image asset. `provider` + `key` abstract the storage backend
/// (R2 today, e.g. Cloudflare Images later); `url` is the delivery URL used as
/// a MediaItem.coverImageUrl.
model MediaAsset {
  id          String         @id @default(uuid())
  // Optional owning item. A media item can have many assets (e.g. multiple
  // cover editions); the display cover is the primary one (MediaItem.cover).
  mediaItemId String?        @map("media_item_id")
  mediaItem   MediaItem?     @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  kind        MediaAssetKind @default(COVER)
  isPrimary   Boolean        @default(false) @map("is_primary")
  position    Int            @default(0) // manual ordering within a kind

  provider    String  @default("r2") // "r2" | "cloudflare_images"
  key         String // R2 object key or provider image id
  url         String // delivery URL (Worker /uploads/<key> for R2)
  contentType String? @map("content_type")
  size        Int?

  // Edition metadata (esp. book covers): which printing this artwork is from.
  edition     String? // e.g. "1st edition", "Deluxe", "UK paperback"
  editionYear Int?    @map("edition_year")
  publisher   String? // publisher of this specific edition

  // Provenance for images sourced from CC libraries (attribution).
  sourceName String? @map("source_name") // e.g. "Wikimedia Commons"
  sourceUrl  String? @map("source_url") // attribution/description page
  license    String? // e.g. "CC BY-SA 4.0", "Public domain"
  creator    String? // artist / attribution

  uploadedById String?  @map("uploaded_by_id")
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([uploadedById])
  @@index([mediaItemId, kind])
  @@map("media_assets")
}

// ---------------------------------------------------------------------------
// TV structure: a TV_SHOW MediaItem has Seasons, each with Episodes. Consumption
// is still logged via MediaEntry (mediaItemId = the show), optionally scoped to
// a season or episode so "mark whole season watched" fans out per episode.
// ---------------------------------------------------------------------------

model Season {
  id          String    @id @default(uuid())
  mediaItemId String    @map("media_item_id")
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  number      Int // season number (0 = specials)
  title       String?
  synopsis    String?
  airDate     DateTime? @map("air_date")
  createdAt   DateTime  @default(now()) @map("created_at")

  episodes Episode[]

  @@unique([mediaItemId, number])
  @@index([mediaItemId])
  @@map("seasons")
}

model Episode {
  id             String    @id @default(uuid())
  seasonId       String    @map("season_id")
  season         Season    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  number         Int // episode number within the season
  title          String?
  synopsis       String?
  director       String? // primary director, when a source provides it (e.g. TMDB)
  runtimeMinutes Int?      @map("runtime_minutes")
  airDate        DateTime? @map("air_date")
  createdAt      DateTime  @default(now()) @map("created_at")

  entries MediaEntry[]

  @@unique([seasonId, number])
  @@index([seasonId])
  @@map("episodes")
}

// ---------------------------------------------------------------------------
// User activity
// ---------------------------------------------------------------------------

/// A single watch/read/listen. Multiple rows per (user, media) enable rewatches.
/// For TV, `episodeId` scopes the entry to one episode (show-level entries leave
/// it null).
model MediaEntry {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItemId   String      @map("media_item_id")
  mediaItem     MediaItem   @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  episodeId     String?     @map("episode_id")
  episode       Episode?    @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  status        EntryStatus @default(COMPLETED)
  startedAt     DateTime?   @map("started_at")
  finishedAt    DateTime?   @map("finished_at")
  /// Free-form progress marker, e.g. "S2E4" or "p. 210".
  progress      String?
  progressValue Int?        @map("progress_value")
  progressUnit  String?     @map("progress_unit") // "episode" | "page" | "chapter" | "minute" | ...
  note          String?
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  @@index([userId, mediaItemId])
  @@index([mediaItemId])
  @@index([userId, finishedAt])
  @@index([episodeId])
  @@map("media_entries")
}

/// 0.5–5 star rating in half-star steps (one per user per media).
model Rating {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItemId String    @map("media_item_id")
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  stars       Decimal   @db.Decimal(2, 1)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@unique([userId, mediaItemId])
  @@index([mediaItemId])
  @@map("ratings")
}

model Review {
  id               String     @id @default(uuid())
  userId           String     @map("user_id")
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItemId      String     @map("media_item_id")
  mediaItem        MediaItem  @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  title            String?
  body             String
  visibility       Visibility @default(PUBLIC)
  containsSpoilers Boolean    @default(false) @map("contains_spoilers")
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  @@unique([userId, mediaItemId])
  @@index([mediaItemId, visibility])
  @@map("reviews")
}

// ---------------------------------------------------------------------------
// Social
// ---------------------------------------------------------------------------

model Follow {
  followerId  String   @map("follower_id")
  follower    User     @relation("follower", fields: [followerId], references: [id], onDelete: Cascade)
  followingId String   @map("following_id")
  following   User     @relation("following", fields: [followingId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")

  @@id([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

/// A user's reaction to a recommendation. UP = "more like this" (a positive
/// taste seed); DOWN = "not for me" (a negative influence on similar items);
/// HIDE = dismiss this one. All three remove the item from the feed.
enum RecommendationSignal {
  UP
  DOWN
  HIDE
}

model RecommendationFeedback {
  id          String               @id @default(uuid())
  userId      String               @map("user_id")
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItemId String               @map("media_item_id")
  mediaItem   MediaItem            @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  signal      RecommendationSignal
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  @@unique([userId, mediaItemId])
  @@index([userId, signal])
  @@map("recommendation_feedback")
}

// ---------------------------------------------------------------------------
// Lists
// ---------------------------------------------------------------------------

model MediaList {
  id           String      @id @default(uuid())
  ownerId      String      @map("owner_id")
  owner        User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  /// Curated icon handle (a lucide icon name; see src/lib/list-icons.ts).
  icon         String?
  visibility   Visibility  @default(PRIVATE)
  /// Which media types may be added. Empty = any type allowed.
  allowedTypes MediaType[] @map("allowed_types")
  ranked       Boolean     @default(false)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  items         MediaListItem[]
  savedBy       SavedList[]
  starredBy     StarredList[]
  collaborators ListCollaborator[]
  notifications Notification[]

  @@index([ownerId])
  @@index([visibility])
  @@map("media_lists")
}

model MediaListItem {
  id          String    @id @default(uuid())
  listId      String    @map("list_id")
  list        MediaList @relation(fields: [listId], references: [id], onDelete: Cascade)
  mediaItemId String    @map("media_item_id")
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  position    Int       @default(0)
  note        String?
  addedAt     DateTime  @default(now()) @map("added_at")

  @@unique([listId, mediaItemId])
  @@index([listId])
  @@map("media_list_items")
}

/// A user following/saving someone else's list. (Collaborative editing of
/// shared lists is a future addition — see PLAN.md.)
model SavedList {
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listId    String    @map("list_id")
  list      MediaList @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")

  @@id([userId, listId])
  @@index([listId])
  @@map("saved_lists")
}

/// A user "starring" a list to pin it prominently (homepage). Distinct from
/// SavedList (following others' lists): a star works on your OWN lists and on
/// lists you've saved.
model StarredList {
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  listId    String    @map("list_id")
  list      MediaList @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now()) @map("created_at")

  @@id([userId, listId])
  @@index([listId])
  @@map("starred_lists")
}

enum CollaboratorStatus {
  PENDING
  ACCEPTED
}

/// A shared-list collaborator. The owner invites a user (status PENDING);
/// accepting flips it to ACCEPTED, granting co-editor rights (add/remove/
/// reorder items, edit notes). Declining deletes the row.
model ListCollaborator {
  id          String             @id @default(uuid())
  listId      String             @map("list_id")
  list        MediaList          @relation(fields: [listId], references: [id], onDelete: Cascade)
  userId      String             @map("user_id")
  user        User               @relation("collaborator", fields: [userId], references: [id], onDelete: Cascade)
  invitedById String             @map("invited_by_id")
  invitedBy   User               @relation("inviter", fields: [invitedById], references: [id], onDelete: Cascade)
  status      CollaboratorStatus @default(PENDING)
  createdAt   DateTime           @default(now()) @map("created_at")

  @@unique([listId, userId])
  @@index([userId, status])
  @@map("list_collaborators")
}

enum NotificationType {
  LIST_INVITE
  CONTENT_SUBMISSION
}

/// In-app notification for a recipient user. `actor` is who triggered it and
/// `list` is the related list (for LIST_INVITE). `readAt` null = unread.
model Notification {
  id        String           @id @default(uuid())
  userId    String           @map("user_id")
  user      User             @relation("recipient", fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  actorId   String?          @map("actor_id")
  actor     User?            @relation("actor", fields: [actorId], references: [id], onDelete: SetNull)
  listId    String?          @map("list_id")
  list      MediaList?       @relation(fields: [listId], references: [id], onDelete: Cascade)
  message   String
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("notifications")
}
